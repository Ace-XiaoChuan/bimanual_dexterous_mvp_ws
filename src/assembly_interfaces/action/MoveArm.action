# Goal

# 机械臂命名空间或逻辑名称，例如 left_arm 或 right_arm；
# right_arm 在当前硬件基线中映射到首个或右侧 Franka Research 3
string arm_name

# 命名运动目标，例如 home、pregrasp 或 grasp
string target_name

# 允许执行的最长时间，单位为秒
float32 timeout_sec
---
# Result

# 动作是否执行成功
bool success

# 错误码，0 表示没有错误
int32 error_code

# 便于阅读的结果说明
string message
---
# Feedback

# 当前内部执行状态
string current_state

# 执行进度，范围为 0.0 到 1.0
float32 progress
